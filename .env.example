# ── Backend (HuggingFace Space) ────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/suraksha_maps?retryWrites=true&w=majority&appName=Cluster0

# JWT Authentication
JWT_SECRET=<generate-a-long-random-string>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — set this to your Vercel frontend URL after deploying
BACKEND_CORS_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]

# Application
ENVIRONMENT=production
EMBEDDING_MODEL=all-MiniLM-L6-v2

# AI
GEMINI_API_KEY=<your-gemini-api-key>

# OCR (optional — leave blank to use tesseract only)
OCR_ENGINE=auto
# AWS_TEXTRACT_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Demo mode (set true only for hackathon demos)
DEMO_MODE=false

# ── Frontend (Vercel) ───────────────────────────────────────────
# Set this in Vercel dashboard → Project Settings → Environment Variables
VITE_API_URL=https://<your-hf-username>-<your-space-name>.hf.space
